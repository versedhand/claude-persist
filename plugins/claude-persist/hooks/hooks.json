{
  "description": "Ralph Wiggum plugin hooks for self-referential loops",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "chmod +x ${CLAUDE_PLUGIN_ROOT}/hooks/*.sh ${CLAUDE_PLUGIN_ROOT}/scripts/*.sh 2>/dev/null; echo 'claude-persist: scripts made executable'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  }
}
